{
  "name": "@seamless-scroll/shared",
  "version": "0.2.2",
  "description": "Shared types for seamless scrolling packages",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "keywords": [
    "scroll",
    "seamless",
    "shared",
    "types"
  ],
  "author": "yeyunwen",
  "license": "MIT",
  "packageManager": "pnpm@10.6.5",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeyunwen/seamless-scroll.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/yeyunwen/seamless-scroll/issues"
  },
  "dependencies": {
    "@seamless-scroll/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "catalog:"
  }
}
